<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme -->
    <style name="Theme.RUCH" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">?android:attr/colorBackground</item>
    </style>
    
    <!-- Card Styles -->
    <style name="LanguageCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>
    
    <!-- Button Styles -->
    <style name="ControlButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="iconSize">24dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">26dp</item>
        <item name="backgroundTint">@color/button_inactive</item>
    </style>
    
    <style name="ControlButtonActive" parent="ControlButtonStyle">
        <item name="backgroundTint">@color/button_active</item>
    </style>
    
    <style name="ControlButtonRecording" parent="ControlButtonStyle">
        <item name="backgroundTint">@color/button_recording</item>
    </style>
    
    <!-- Text Styles -->
    <style name="LanguageLabelStyle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
    </style>
    
    <style name="TranslationTextStyle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>
</resources>
